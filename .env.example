# Silver Estimate runtime environment controls
#
# The application stores user-facing preferences in QSettings. These are the
# only environment variables consumed by the runtime.

# Enable verbose application diagnostics (true/false).
# SILVER_APP_DEBUG=false

# Override the directory used for rotating application log files.
# SILVER_APP_LOG_DIR=D:\SilverEstimate\logs

# Keep a console window visible for packaged Windows diagnostics (true/false).
# SILVER_SHOW_CONSOLE=false
